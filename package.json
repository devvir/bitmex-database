{
  "name": "@devvir/bitmex-database",
  "version": "1.1.4",
  "description": "In-memory BitMEX Database (live state from WS partials and deltas)",
  "author": "devvir",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@devvir/bitmex-api": "^1.2.0",
    "lodash.clonedeep": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/lodash.clonedeep": "^4.5.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
